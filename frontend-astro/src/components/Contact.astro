---
import { client, urlFor } from "../lib/sanity";
import WidthContainer from "./WidthContainer.astro";
import ExternalLinkIcon from "./icons/ExternalLink.astro";
import CopyIcon from "./icons/Copy.astro";

const data = await client.fetch(`*[_type == "homePage"][0] { 
  contactSectionTitle,
  email,
  linkedinLink,
  contactSectionImage
}`);

const {
  contactSectionTitle = "You can reach me here",
  email,
  linkedinLink,
  contactSectionImage,
} = data || {};
---

<WidthContainer>
  <section id="contact" class="contact-section">
    <div class="info-wrapper">
      <h2 class="title">{contactSectionTitle}</h2>
      <div class="links-wrapper">
        {
          email && (
            <button
              class="contact-link hover-underline js-copy-email"
              data-email={email}
              aria-label="Copy email"
              id="email-copy-btn"
            >
              <span class="email-container">
                <span class="email-text js-email-text">{email}</span>
                <span class="copied-text js-copied-text">
                  Email was copied!
                </span>
              </span>
              <CopyIcon class="icon" />
            </button>
          )
        }

        {
          linkedinLink && (
            <a
              href={linkedinLink}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link hover-underline"
              id="linkedin-link"
            >
              <span>LinkedIn</span>
              <ExternalLinkIcon class="icon" />
            </a>
          )
        }
      </div>
    </div>

    {
      contactSectionImage && (
        <div class="contact-image-wrapper">
          <WidthContainer>
            <img
              src={urlFor(contactSectionImage).url()}
              alt=""
              class="contact-image"
            />
          </WidthContainer>
        </div>
      )
    }
  </section>
</WidthContainer>

<style>
  .contact-section {
    min-height: 400px;
    display: flex;
    justify-content: space-between;
  }

  .contact-image-wrapper {
    width: 100%;
    position: absolute;
    bottom: 0;
    right: 0;
    z-index: -1;
  }

  .contact-image {
    max-width: 800px;
    margin-left: auto;
  }

  .info-wrapper {
    margin-top: var(--spacing-128);
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-32);
  }

  .links-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-32);
  }

  .title {
    font-size: var(--font-size-32-40);
    font-weight: 700;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-12);
    font-size: var(--font-size-20-24);
    font-weight: 600;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    color: inherit;
    position: relative;
  }

  .email-container {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .email-text {
    transition:
      opacity 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .copied-text {
    position: absolute;
    left: 0;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    color: var(--black);
    font-weight: 400;
    pointer-events: none;
    white-space: nowrap;
  }

  .is-copied .email-text {
    opacity: 0;
    transform: translateY(-10px);
  }

  .is-copied .copied-text {
    opacity: 1;
    transform: translateY(0);
  }

  .icon {
    width: var(--font-size-24-32);
    height: var(--font-size-24-32);
  }

  @media (max-width: 48rem) {
    .contact-section {
      margin-top: var(--spacing-64);
      flex-direction: column;
      gap: var(--spacing-32);
    }

    .contact-image {
      margin-right: calc(var(--spacing-16) * -1);
      max-width: 100%;
    }

    .info-wrapper {
      margin: 0;
    }

    .links-wrapper {
      gap: var(--spacing-16);
    }
  }
</style>

<script>
  import { trackEvent } from "../lib/analytics";

  const copyButtons = document.querySelectorAll(".js-copy-email");

  copyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const email = button.getAttribute("data-email");
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);

        // Track email copy
        trackEvent("email_copy", {
          email: email,
        });

        // Add visual feedback class
        button.classList.add("is-copied");

        // Remove feedback after 2.5 seconds
        setTimeout(() => {
          button.classList.remove("is-copied");
        }, 2500);
      } catch (err) {
        console.error("Failed to copy email: ", err);
      }
    });
  });

  // Track LinkedIn link click
  const linkedinLink = document.getElementById("linkedin-link");
  linkedinLink?.addEventListener("click", () => {
    trackEvent("linkedin_click", {
      url: linkedinLink.getAttribute("href"),
    });
  });
</script>
