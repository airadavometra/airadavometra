---
import WidthContainer from "./WidthContainer.astro";
import MenuIcon from "./icons/Menu.astro";
import LinkedinIcon from "./icons/Linkedin.astro";
import GithubIcon from "./icons/Github.astro";
import DownloadCvButton from "./DownloadCvButton.astro";
import { client } from "../lib/sanity";

const data = await client.fetch(
  `*[_type == "homePage"][0] { 
    githubLink, 
    linkedinLink, 
    "cvUrl": cvFile.asset->url
  }`,
);
const { githubLink, linkedinLink, cvUrl } = data || {};
---

<header class="header js-header">
  <WidthContainer>
    <div class="header-content">
      <nav class="navigation desktop-only">
        <a href="#experience" class="nav-link hover-underline"
          ><span>Experience</span></a
        >
        <a href="#skills" class="nav-link hover-underline"
          ><span>Skills</span></a
        >
        <a href="#projects" class="nav-link hover-underline"
          ><span>Pet Projects</span></a
        >
        <a href="#contacts" class="nav-link hover-underline"
          ><span>Contact</span></a
        >
      </nav>

      <div class="mobile-only">
        <button class="menu-button" aria-label="Menu">
          <MenuIcon class="icon" />
        </button>
      </div>

      <div class="actions">
        {
          githubLink && (
            <a
              href={githubLink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
              class="icon-link hover-scale"
            >
              <GithubIcon class="icon" />
            </a>
          )
        }
        {
          linkedinLink && (
            <a
              href={linkedinLink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="icon-link hover-scale"
            >
              <LinkedinIcon class="icon" />
            </a>
          )
        }
        {cvUrl && <DownloadCvButton cvUrl={cvUrl} />}
      </div>
    </div>
  </WidthContainer>
</header>

<script>
  const header = document.querySelector(".js-header");

  const updateHeader = () => {
    if (!header) return;
    const scrollY = window.scrollY;
    const threshold = window.innerHeight * 0.5; // 50vh

    if (scrollY > threshold) {
      header.classList.add("header--scrolled");
    } else {
      header.classList.remove("header--scrolled");
    }
  };

  window.addEventListener("scroll", updateHeader);
  // Initial check
  updateHeader();
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    font-size: var(--font-size-16-20);
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .header--scrolled {
    background-color: var(--white);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-16) 0;
  }

  .navigation {
    display: flex;
    gap: var(--spacing-32);
  }

  .nav-link {
    transition: any 0.2s ease;
  }

  .nav-link:hover {
  }

  .actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-32);
  }

  .icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .icon-link:hover {
  }

  .menu-button {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .menu-button:hover {
  }

  .icon {
    width: var(--font-size-24-32);
    height: var(--font-size-24-32);
  }

  .desktop-only {
    display: flex;
  }

  .mobile-only {
    display: none;
  }

  @media (max-width: 48rem) {
    .desktop-only {
      display: none;
    }
    .mobile-only {
      display: block;
    }
    .actions {
      gap: var(--spacing-16);
    }
  }
</style>
